PORT=3000
NODE_ENV=development
# Generate a random 64-char string: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-64-char-string
ADMIN_EMAIL=admin@example.com
# Will be hashed with bcrypt at server startup
ADMIN_PASSWORD=change-this-password
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGIN=http://localhost:3000,https://your-app.onrender.com
WHATSAPP_NUMBER=27677834591
DB_PATH=data.db
# Change this to your production URL when deploying
SITE_URL=http://localhost:3000

# Email via Brevo API (free tier: 300 emails/day)
# Sign up at https://brevo.com and get your API key
BREVO_API_KEY=your-brevo-api-key

# WhatsApp notifications (UltraMsg — free, sign up at https://ultramsg.com)
WHATSAPP_INSTANCE_ID=your-instance-id
WHATSAPP_TOKEN=your-whatsapp-token

# PayFast payment gateway (register free at https://payfast.co.za)
# Sandbox testing: set PAYFAST_SANDBOX=true, use sandbox credentials from https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_SANDBOX=true

# Web Push (VAPID) — generate at https://web-push-codelab.glitch.me/
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
