# Email (Choose ONE provider below)
# Option 1: Gmail (use an app password from Google Account > Security > App passwords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Option 2: SendGrid (recommended — better deliverability, free tier: 100 emails/day)
# Sign up at https://sendgrid.com, create API key, use "apikey" as SMTP_USER
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# Option 3: Mailgun (free tier: 100 emails/day)
# Sign up at https://mailgun.com, find SMTP credentials in Domains > SMTP
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your-mailgun-smtp-password
# Common config (uncomment the one you use):
